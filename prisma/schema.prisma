// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERVISOR
  OPERATIONAL
}

enum Regional {
  DF02
  DF03
}

enum TechnicianType {
  CLT
  TER
}

enum ClosureAgent {
  RYAN
  NAYANE
  WALISSON
  JADE
  ABRAAO
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  regional  Regional
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model City {
  id                 String       @id @default(cuid())
  name               String
  regional           Regional
  order              Int          @default(0)
  technicians        Technician[] @relation("PrimaryCity")
  supportTechnicians Technician[] @relation("SupportCity")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([name, regional])
  @@map("cities")
}

model Technician {
  id             String         @id @default(cuid())
  code           String         // ex: 518
  name           String
  type           TechnicianType
  canField       Boolean        @default(true)
  canDelivery    Boolean        @default(true)
  canPickup      Boolean        @default(false)
  canDoorRelease Boolean        @default(false)
  osField        Int            @default(0)
  osDelivery     Int            @default(0)
  osPickup       Int            @default(0)
  osDoorRelease  Int            @default(0)
  osLimit        Int            @default(20)
  onLeave        Boolean        @default(false) // Folga / Férias
  onPickup       Boolean        @default(false) // Compatibilidade com status antigo
  regional       Regional
  cityId         String?
  city           City?          @relation("PrimaryCity", fields: [cityId], references: [id])
  supportCityId  String?
  supportCity    City?          @relation("SupportCity", fields: [supportCityId], references: [id])
  order          Int            @default(0)
  sharedCellId   String?
  dayPlans       TechnicianDayPlan[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("technicians")
}

model TechnicianDayPlan {
  id            String     @id @default(cuid())
  technicianId  String
  technician    Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  dateKey       String
  cityId        String?
  supportCityId String?
  osField       Int        @default(0)
  osDelivery    Int        @default(0)
  osPickup      Int        @default(0)
  osDoorRelease Int        @default(0)
  onLeave       Boolean    @default(false)
  onPickup      Boolean    @default(false)
  order         Int        @default(0)
  sharedCellId  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([technicianId, dateKey])
  @@index([dateKey])
  @@map("technician_day_plans")
}

model ClosureRecord {
  id          String       @id @default(cuid())
  agent       ClosureAgent
  regional    Regional
  closureDate String // dateKey "YYYY-MM-DD" (data do encerramento)
  clientCode  String?
  clientName  String?
  osNumber    String?
  createdAt   DateTime     @default(now())

  @@index([closureDate])
  @@map("closure_records")
}
